# ──────────────────────────────────────────────────────────
# Сервер
# ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────────────────────
# Внутренняя БД (PostgreSQL — портальная)
# ──────────────────────────────────────────────────────────
DB_INTERNAL_HOST=localhost
DB_INTERNAL_PORT=5432
DB_INTERNAL_NAME=tppo_portal
DB_INTERNAL_USER=tppo
DB_INTERNAL_PASS=tppo_pass

# ──────────────────────────────────────────────────────────
# Внешняя БД (PostgreSQL — симуляция 1С)
# ──────────────────────────────────────────────────────────
DB_EXTERNAL_HOST=localhost
DB_EXTERNAL_PORT=5433
DB_EXTERNAL_NAME=neo_1c
DB_EXTERNAL_USER=tppo
DB_EXTERNAL_PASS=tppo_pass

# ──────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_32CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_32CHARS_MIN
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ──────────────────────────────────────────────────────────
# MinIO / S3
# ──────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tppo-files
S3_REGION=us-east-1
# Публичный URL для клиентов (если MinIO за прокси — измените)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# ──────────────────────────────────────────────────────────
# SMS (в режиме dev код возвращается в ответе)
# ──────────────────────────────────────────────────────────
SMS_DEV_MODE=true
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=

# ──────────────────────────────────────────────────────────
# Синхронизация с внешней БД
# ──────────────────────────────────────────────────────────
SYNC_INTERVAL_MS=30000
OUTBOX_POLL_INTERVAL_MS=5000
